# Unsplash Configuration (used by Python ETL)
# Get your access key from: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_USERNAME=joaohfrodrigues

# Cache Configuration (used by Python ETL)
# How long to cache Unsplash photos (in minutes) to reduce API calls
# Unsplash free tier: 50 requests/hour
CACHE_DURATION_MINUTES=30

# Keystatic CMS (Next.js)
# Required in production — used to encrypt the GitHub OAuth session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYSTATIC_SECRET=your_keystatic_secret

# Keystatic GitHub OAuth (production only)
# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://your-domain.com/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=your_github_oauth_client_id
KEYSTATIC_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
